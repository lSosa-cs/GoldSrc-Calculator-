<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Calculadora de Tarifa Freelance Pro</title>
    <!-- Tailwind CSS para un diseño moderno -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-50 text-gray-800 font-sans antialiased">

    <div class="max-w-4xl mx-auto p-6">
        <header class="text-center my-8">
            <h1 class="text-4xl font-extrabold text-indigo-600 mb-2">Calculadora de Tarifa Freelance</h1>
            <p class="text-gray-500">Descubre cuánto debes cobrar por hora para alcanzar tus metas financieras.</p>
        </header>

        <main class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Columna de Inputs -->
            <section class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 space-y-6">
                <h2 class="text-xl font-bold text-gray-700 border-b pb-2">Tus Datos Financieros</h2>
                
                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Gastos Mensuales (Vida + Negocio)</label>
                    <input type="number" id="gastos" value="1500" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Ahorro Mensual Deseado</label>
                    <input type="number" id="ahorro" value="500" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">Porcentaje de Impuestos (%)</label>
                    <input type="number" id="impuestos" value="20" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                </div>

                <h2 class="text-xl font-bold text-gray-700 border-b pb-2 pt-4">Tiempo de Trabajo</h2>

                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Semanas de Vacaciones/Año</label>
                        <input type="number" id="vacaciones" value="4" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-gray-600 mb-1">Horas de Trabajo/Semana</label>
                        <input type="number" id="horasSemana" value="40" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-600 mb-1">% de Tiempo Facturable (Efectivo)</label>
                    <p class="text-xs text-gray-400 mb-1">El resto del tiempo se va en reuniones, buscar clientes, administración, etc.</p>
                    <input type="number" id="efectividad" value="70" class="w-full p-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-indigo-500 focus:outline-none">
                </div>
            </section>

            <!-- Columna de Resultados -->
            <section class="flex flex-col justify-between space-y-6">
                <div class="bg-indigo-600 text-white p-8 rounded-2xl shadow-lg flex flex-col justify-center items-center text-center h-full">
                    <h3 class="text-lg font-medium opacity-80 uppercase tracking-wider">Tu Tarifa Sugerida por Hora</h3>
                    <div class="text-6xl font-black my-4">$<span id="resultadoHora">0.00</span></div>
                    <p class="text-sm opacity-90">Para cubrir tus gastos, ahorrar y pagar impuestos con tu ritmo de trabajo actual.</p>
                </div>

                <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 space-y-3">
                    <h3 class="font-bold text-gray-700">Desglose Anual Estimado:</h3>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Necesidad Neta (Gastos + Ahorro):</span> <span id="netaAnual" class="font-semibold">$0.00</span></div>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Facturación Bruta (Con Impuestos):</span> <span id="brutaAnual" class="font-semibold text-green-600">$0.00</span></div>
                    <div class="flex justify-between text-sm"><span class="text-gray-500">Horas Facturables al Año:</span> <span id="horasAnuales" class="font-semibold text-indigo-600">0 hrs</span></div>
                </div>
            </section>
        </main>
    </div>

    <!-- Lógica en JavaScript para actualización en tiempo real -->
    <script>
        const inputs = ['gastos', 'ahorro', 'impuestos', 'vacaciones', 'horasSemana', 'efectividad'];
        
        function calcular() {
            // Obtener valores
            const gastosMensuales = parseFloat(document.getElementById('gastos').value) || 0;
            const ahorroMensual = parseFloat(document.getElementById('ahorro').value) || 0;
            const impuestoPorcentaje = parseFloat(document.getElementById('impuestos').value) || 0;
            const semanasVacaciones = parseFloat(document.getElementById('vacaciones').value) || 0;
            const horasSemana = parseFloat(document.getElementById('horasSemana').value) || 0;
            const efectividad = parseFloat(document.getElementById('efectividad').value) || 0;

            // Cálculos Financieros
            const netoMensual = gastosMensuales + ahorroMensual;
            const netoAnual = netoMensual * 12;
            const brutoAnual = netoAnual / (1 - (impuestoPorcentaje / 100));

            // Cálculos de Tiempo
            const semanasLaborables = 52 - semanasVacaciones;
            const horasTeoricasAnuales = semanasLaborables * horasSemana;
            const horasFacturablesAnuales = horasTeoricasAnuales * (efectividad / 100);

            // Resultado Final
            const tarifaHora = horasFacturablesAnuales > 0 ? (brutoAnual / horasFacturablesAnuales) : 0;

            // Renderizar en pantalla
            document.getElementById('resultadoHora').innerText = tarifaHora.toFixed(2);
            document.getElementById('netaAnual').innerText = '$' + netoAnual.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('brutaAnual').innerText = '$' + brutoAnual.toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2});
            document.getElementById('horasAnuales').innerText = Math.round(horasFacturablesAnuales) + ' hrs';
        }

        // Escuchar cambios en todos los inputs para recalcular en tiempo real
        inputs.forEach(id => {
            document.getElementById(id).addEventListener('input', calcular);
        });

        // Ejecutar cálculo inicial
        calcular();
    </script>
</body>
</html>
